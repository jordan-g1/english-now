{
  "cli": {
    "version": ">= 18.8.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "simulator": {
      "developmentClient": true,
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "sdk-55"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
